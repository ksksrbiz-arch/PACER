# Environment
ENV=production

# 1COMMERCE LLC Entity (used in all compliance logs)
LLC_ENTITY=1COMMERCE LLC

# PACER PCL API credentials (https://pacer.uscourts.gov)
PACER_USERNAME=your_pacer_username
PACER_PASSWORD=your_pacer_password

# CourtListener / RECAP (optional — free tier works without key)
COURTLISTENER_API_KEY=

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://pacer:pacer@localhost:5432/pacer
DATABASE_URL_SYNC=postgresql+psycopg2://pacer:pacer@localhost:5432/pacer

# Clearbit (domain enrichment)
CLEARBIT_API_KEY=

# Ahrefs (SEO scoring)
AHREFS_API_KEY=

# OpenAI (GPT-4o topical relevance scoring)
OPENAI_API_KEY=sk-...

# Ahrefs (SEO scoring)
AHREFS_API_KEY=

# Doma (RWA tokenization)
DOMA_API_KEY=
DOMA_API_BASE=https://api.doma.com/v1

# Securitize (hybrid settlement / DFR exemption)
SECURITIZE_API_KEY=
SECURITIZE_API_BASE=https://api.securitize.io/v1

# Drop-catch registrars
DYNADOT_API_KEY=
DROPCATCH_API_KEY=
NAMEJET_API_KEY=

# Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# WhoisXML
WHOISXML_API_KEY=

# APScheduler cron (default: 3 AM UTC)
PIPELINE_CRON_HOUR=3
PIPELINE_CRON_MINUTE=0

# Scoring threshold for drop-catch / RWA queuing
SCORE_THRESHOLD=60
