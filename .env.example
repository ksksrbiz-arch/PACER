# ─── PACER :: 1COMMERCE LLC ──────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# LLC / Compliance tagging
LLC_ENTITY="1COMMERCE LLC"
LLC_STATE="OR"
LLC_CITY="Canby"
LLC_EIN=""

# Database
DATABASE_URL=postgresql+asyncpg://pacer:pacer@postgres:5432/pacer
SYNC_DATABASE_URL=postgresql://pacer:pacer@postgres:5432/pacer

# Redis (circuit-breaker + rate-limit state)
REDIS_URL=redis://redis:6379/0

# PACER PCL + RECAP
PACER_USERNAME=
PACER_PASSWORD=
PACER_CLIENT_CODE=
COURTLISTENER_API_TOKEN=

# EDGAR / SEC
SEC_USER_AGENT="1COMMERCE LLC pacer-ops skdev@1commercesolutions.com"

# USPTO TSDR
USPTO_API_KEY=

# Scoring
AHREFS_API_TOKEN=
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=
SEMRUSH_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LLM provider — claude (primary) | groq (free fallback) | openai (legacy)
# On rate-limit the engine automatically falls back down the chain.
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# Groq free-tier (https://console.groq.com) — llama-3.3-70b-versatile is free
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# WHOIS / Domain
WHOISXML_API_KEY=

# Enrichment
CLEARBIT_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=
CRUNCHBASE_API_KEY=

# Registrars / drop-catch
DYNADOT_API_KEY=
DROPCATCH_USER=
DROPCATCH_KEY=
NAMEJET_USER=
NAMEJET_KEY=
GODADDY_API_KEY=
GODADDY_API_SECRET=

# RWA — Doma Protocol
DOMA_API_URL=https://api.doma.xyz
DOMA_API_KEY=
DOMA_WALLET_PRIVATE_KEY=
DOMA_CHAIN_ID=1

# Settlement — Securitize
SECURITIZE_API_URL=https://api.securitize.io/v2
SECURITIZE_API_KEY=
SECURITIZE_ISSUER_ID=

# Monetization
PARKING_PROVIDER=sedo
PARKING_API_KEY=
AFFILIATE_DEFAULT_TAG=1commerce-20

# Alerts
SLACK_WEBHOOK_URL=
ALERT_CHANNEL=#pacer-ops

# Scheduler
SCHEDULE_CRON_HOUR=3
SCHEDULE_CRON_MINUTE=0
SCORE_THRESHOLD_DROPCATCH=60
SCORE_THRESHOLD_PARKING=40

# Env
ENVIRONMENT=production
LOG_LEVEL=INFO
